# Railway will provide DATABASE_URL automatically if you add a Postgres service and link it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Railway provides PORT automatically.
API_GLOBAL_PREFIX="api/v1"

# Replace in Railway Variables.
JWT_SECRET="replace-me"
JWT_EXPIRES_IN="7d"

# Optional
VAT_RATE_PERCENT=0

# Used for absolute links generated by the API (e.g. invoice PDF URLs)
PUBLIC_BASE_URL="https://YOUR-RAILWAY-API.up.railway.app"

FILE_STORAGE_DIR="storage"

# Optional SMTP config
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="no-reply@example.com"
